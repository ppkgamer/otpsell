# Database - ใช้ Neon (free): https://neon.tech หรือ local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/otpreader"

# JWT
JWT_SECRET="change-this-to-a-long-random-string"

# Google OAuth2 - สร้างใน Google Cloud Console (free)
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/gmail/callback"

# URLs
FRONTEND_URL="http://localhost:5173"
PORT=3001

# Admin seed (ใช้ตอน npm run db:seed)
ADMIN_EMAIL="admin@otpreader.com"
ADMIN_PASSWORD="admin123"
